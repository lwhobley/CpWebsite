          <p>A $12K fine and 48 hour shut down from one missed doc exposed the insanity. No tool existed for independent operators. Time to build it.</p>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">2026</div>
          <h4>ComplianceDaddy Live</h4>
          <p>AI audits, checklists, reports—for bars/restaurants/nightclubs. </p>
        </div>
      </div>
    </section>

    <!-- MISSION -->
    <section class="mission-section">
      <div class="mission-label">Our Mission</div>
      <div>
        <p class="mission-quote">emPrecision compliance for pros.em<br>Because venues deserve ops that scale, not binders that bury you.</p>
        <div style="margin-top: 48px;">
          <button class="btn-primary" onclick="openWaitlist()">Join the Waitlist</button>
        </div>
      </div>
    </section>

    <!-- FULL BLEED CTA -->
    <section class="fullbleed-cta" style="min-height: 440px;">
      <div class="fullbleed-bg">
        <img src="https://images.unsplash.com/photo-1560053608-13721b19a8e1?w=1600&q=85" alt="Upscale hospitality venue" loading="lazy">
      </div>
      <div class="fullbleed-overlay"></div>
      <div class="fullbleed-content">
        <div class="eyebrow" style="margin-bottom: 20px;">Early Access</div>
        <h2>Be first.<br>Founding empricingem locked.</h2>
        <button class="btn-primary-white" onclick="openWaitlist()" style="margin-top: 32px;">Secure My Spot</button>
      </div>
    </section>

    <div id="footer-about"></div>
  </div>

  <!-- WAITLIST & SUCCESS MODALS - copy exact from Index -->
  <div class="overlay" id="waitlistOverlay" onclick="if(event.target===this) closeWaitlist()">
    <div class="modal-box">
      <button class="modal-close" onclick="closeWaitlist()">&times;</button>
      <h3>Join the Waitlist</h3>
      <p class="sub">Early access for operators who move first. Lock in founding pricing.</p>
      <form id="waitlistForm" onsubmit="submitWaitlist(event)">
        <div class="field"><label>Full Name</label><input type="text" id="wl-name" placeholder="Jane Smith" required></div>
        <div class="field"><label>Email Address</label><input type="email" id="wl-email" placeholder="jane@yourbar.com" required></div>
        <div class="field"><label>Venue Type</label>
          <select id="wl-venue" required>
            <option value="" disabled selected>Select your venue type</option>
            <option>Bar / Cocktail Lounge</option>
            <option>Nightclub</option>
            <option>Restaurant</option>
            <option>Rooftop / Event Space</option>
            <option>Hotel Bar</option>
            <option>Multi-venue Group</option>
            <option>Other</option>
          </select>
        </div>
        <button type="submit" class="btn-primary" style="width: 100%; justify-content: center; margin-top: 8px;">Secure My Spot</button>
      </form>
    </div>
  </div>
  <div class="overlay" id="successOverlay" onclick="if(event.target===this) closeSuccess()">
    <div class="modal-box success-box" style="text-align: center;">
      <button class="modal-close" onclick="closeSuccess()">&times;</button>
      <span class="success-icon">&#10003;</span>
      <h3>You're in.</h3>
      <p class="sub">Early access incoming. We'll reach out with your founding-member details as we approach launch. Welcome to the crew.</p>
      <button class="btn-primary" onclick="closeSuccess()" style="width: 100%; justify-content: center; margin-top: 8px;">Back to Exploring</button>
    </div>
  </div>

  <!-- FOOTER TEMPLATE - same as Index -->
  <template id="footerTpl">
    <!-- Paste exact footer content from Index.html here -->
    <footer>
      <div class="footer-top">
        <div class="footer-brand">
          <span class="footer-logo">COMPLIANCE<span>DADDY</span></span>
          <p class="footer-tagline">Hospitality compliance, automated. Built by operators, for operators. Pre-launch Mobile, AL.</p>
          <!-- socials etc. -->
        </div>
        <!-- other cols -->
      </div>
      <div class="footer-bottom">
        <p>2026 ComplianceDaddy. All rights reserved.</p>
        <p>Mobile, AL Pre-Launch</p>
      </div>
    </footer>
  </template>

  <script>
    // Exact JS from Index.html: cursor, routing (adapt for standalone/about active), modals, footer injection, mobile nav, etc.
    // Key functions:
    function navigate(page) { /* ... full routing code ... */ }
    function openWaitlist() { document.getElementById('waitlistOverlay').classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeWaitlist() { document.getElementById('waitlistOverlay').classList.remove('open'); document.body.style.overflow = ''; }
    function closeSuccess() { document.getElementById('successOverlay').classList.remove('open'); document.body.style.overflow = ''; }
    function submitWaitlist(e) {
      e.preventDefault();
      const name = document.getElementById('wl-name').value;
      const email = document.getElementById('wl-email').value;
      const venue = document.getElementById('wl-venue').value;
      window.location.href = `mailto:info@compliancedaddy.com?subject=Waitlist%20Signup:%20${encodeURIComponent(name)}&body=Name:%20${encodeURIComponent(name)}%0AEmail:%20${encodeURIComponent(email)}%0AVenue:%20${encodeURIComponent(venue)}`;
      closeWaitlist();
      document.getElementById('waitlistForm').reset();
      setTimeout(() => document.getElementById('successOverlay').classList.add('open'), 400);
    }
    function toggleMobile() { /* ... */ }
    function injectFooters() { /* ... */ }
    // Cursor animation
    const curDot = document.getElementById('cur-dot');
    const curRing = document.getElementById('cur-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      curDot.style.left = mx + 'px';
      curDot.style.top = my + 'px';
    });
    function animRing() {
      rx += (mx - rx) * 0.15;
      ry += (my - ry) * 0.15;
      curRing.style.left = rx + 'px';
      curRing.style.top = ry + 'px';
      requestAnimationFrame(animRing);
    }
    document.addEventListener('mousedown', () => curRing.style.transform = 'translate(-50%, -50%) scale(0.75)');
    document.addEventListener('mouseup', () => curRing.style.transform = 'translate(-50%, -50%) scale(1)');
    requestAnimationFrame(animRing);
    // Init
    document.addEventListener('DOMContentLoaded', () => {
      injectFooters();
      // Set about active for standalone
      setActiveNav('about');
    });
    // Paste full JS from Index for full compatibility (routing, etc.)
  </script>
</body>
